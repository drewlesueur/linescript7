PRINT STRING start
SLEEP 300
THEN "AFTER_300"
PRINT STRING after scheduling 300ms

DONE tag
    PRINT STRING cb:
    PRINT tag
END

sleeps = {count: 3 finalCb: "ALL_DONE"}
SLEEP 20
THEN "WAIT_SLEEP" sleeps
SLEEP 10
THEN "WAIT_SLEEP" sleeps
SLEEP 30
THEN "WAIT_SLEEP" sleeps
WAIT_SLEEP sleeps
    sleeps.count -= 1
    IF sleeps.count IS 0
        CALL sleeps.finalCb sleeps
    END
END
ALL_DONE sleeps
    PRINT "yay all done" 
END

PRINT STRING scheduling callbacks
SLEEP 200
THEN "DONE" "first"
SLEEP 400
THEN "DONE" "second"
SLEEP 100
THEN "DONE" "third"

PRINT STRING after scheduling
SLEEP 700
THEN "AFTER_1S"

SLEEP 3000
THEN "DONE" "after 3 seconds"

AFTER_300
    PRINT STRING after 300ms
END

AFTER_1S
    PRINT STRING after 1s total
END
